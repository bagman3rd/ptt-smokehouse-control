DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Required. At least 12 characters. No default admin password exists in Build 2.6.0+.
ADMIN_PASSWORD="replace-with-a-long-random-admin-password"
# Required. At least 12 characters. Use a long random token. No dev fallback is used in Build 2.6.0+.
APP_SESSION_TOKEN="replace-with-a-long-random-session-token"
NEXT_PUBLIC_APP_NAME="PTT Smokehouse Control"
