DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Required. At least 12 characters. Used only to seed/reset the initial admin account.
ADMIN_PASSWORD="replace-with-a-long-random-admin-password"
# Required. At least 12 characters. Use a long random token. No dev fallback is used.
APP_SESSION_TOKEN="replace-with-a-long-random-session-token"
NEXT_PUBLIC_APP_NAME="Smokehouse Control"
