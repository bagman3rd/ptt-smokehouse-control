DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Required. At least 12 characters. Used only to seed/reset the initial admin account.
ADMIN_PASSWORD="replace-with-a-long-random-admin-password"
# Required. At least 12 characters. Use a long random token. No dev fallback is used.
APP_SESSION_TOKEN="replace-with-a-long-random-session-token"
NEXT_PUBLIC_APP_NAME="Smokehouse Control"
# Required for scheduled backup endpoint / Render Cron.
CRON_SECRET="replace-with-a-long-random-cron-secret"
# Base URL for Render Cron runner, e.g. https://ptt-smokehouse-control.onrender.com
BACKUP_APP_URL="https://example.onrender.com"
# Optional webhook/storage endpoint that receives tenant JSON backup payloads.
BACKUP_POST_URL=""
# Build 4.4.0 commercial readiness
NEXT_PUBLIC_SUPPORT_EMAIL=support@smokehousecontrol.com
STRIPE_PAYMENT_LINK=
STRIPE_CHECKOUT_URL=
# Build 5.2.0 commercial SaaS readiness
STRIPE_MONTHLY_PAYMENT_LINK=
STRIPE_ANNUAL_PAYMENT_LINK=
STRIPE_CUSTOMER_PORTAL_URL=
STRIPE_PORTAL_URL=
