generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmokehouseScenario {
  id              String   @id @default(cuid())
  name            String
  dailySales      Int
  meatCostPercent Float
  laborPercent    Float
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProductionCheck {
  id        String   @id @default(cuid())
  area      String
  item      String
  status    String   @default("open")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
