generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OWNER
  KITCHEN_MANAGER
  KITCHEN_CREW
  CONSULTANT
  KM
  PITMASTER
  VIEWER
}

enum ScenarioType {
  CONSERVATIVE
  BASE
  AGGRESSIVE
  EVENT_DAY
}

enum ProteinUnit {
  EACH
  RACK
  LB_RAW
  LB_COOKED
}

enum PosProvider {
  SQUARE
  TOAST
  CLOVER
  LIGHTSPEED
  TOUCHBISTRO
  SPOTON
  REVEL
  ORACLE_SIMPHONY
  NCR_ALOHA
  PAR_BRINK
}

enum PosConnectionStatus {
  NOT_CONNECTED
  CONNECTING
  CONNECTED
  DEGRADED
  REAUTH_REQUIRED
  DISCONNECTED
}

enum PosSyncStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
  SKIPPED
}

model Restaurant {
  id          String   @id @default(cuid())
  name        String
  slug        String?
  city        String?
  state       String?
  timezone    String   @default("America/New_York")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  users       User[]
  memberships RestaurantMembership[]
  proteins    Protein[]
  savedReports SavedReport[]
  reportRuns  ReportRun[]
  scenarios   ForecastScenario[]
  dayMultipliers DayMultiplier[]
  monthMultipliers MonthMultiplier[]
  eventModifiers EventModifier[]
  cookPlans   CookPlan[]
  cookPlanItems CookPlanItem[]
  eodLogs     EndOfDayLog[]
  eodProteinLogs EndOfDayProteinLog[]
  auditLogs   AuditLog[]
  smokers     Smoker[]
  learningRecommendations LearningRecommendation[]
  systemChecks SystemCheck[]
  subscriptions Subscription[]
  supportTickets SupportTicket[]
  dataRequests CustomerDataRequest[]
  menuItemMappings MenuItemMapping[]
  posImportBatches PosImportBatch[]
  posImportRows PosImportRow[]
  posConnections PosConnection[]
  posSyncRuns PosSyncRun[]
  posRawRecords PosRawRecord[]
  posMenuItems PosMenuItem[]
  posOrders PosOrder[]
  posLineItems PosLineItem[]
  posWebhookEvents PosWebhookEvent[]
}

model RestaurantMembership {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role       @default(KITCHEN_CREW)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
  @@unique([restaurantId, userId])
  @@index([userId])
  @@index([restaurantId, active])
}

model AuditLog {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  actorUserId  String?
  actorName    String   @default("System")
  action       String
  entity       String
  entityId     String?
  beforeJson   String?
  afterJson    String?
  createdAt    DateTime @default(now())
  @@index([restaurantId, createdAt])
  @@index([action, createdAt])
}

model User {
  id           String   @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  memberships  RestaurantMembership[]
  sessions     UserSession[]
  name         String
  username     String?
  email        String
  passwordHash String?
  sessionVersion Int    @default(1)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  twoFactorRecoveryCodes String?
  twoFactorRecoveryDisplay String?
  twoFactorKeyVersion Int @default(1)
  passwordResetRequired Boolean @default(false)
  failedLoginCount Int  @default(0)
  lockedUntil  DateTime?
  lastFailedLoginAt DateTime?
  role         Role     @default(KITCHEN_CREW)
  active       Boolean  @default(true)
  createdBy    String   @default("System")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  @@index([restaurantId])
  @@index([active])
  @@index([username])
  @@index([email])
}


model UserSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model Protein {
  id                  String      @id @default(cuid())
  restaurantId        String
  restaurant          Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name                String
  code                String      @default("OTHER")
  inputUnit           ProteinUnit
  rawWeightEachLb     Float       @default(0)
  cookedWeightEachLb  Float       @default(0)
  cookedYieldPercent  Float       @default(50)
  avgSalesPerCookedLb Float       @default(22)
  purchaseCostEach    Float       @default(0)
  salesPriceEach      Float       @default(0)
  sandwichOz          Float       @default(5)
  plateOz             Float       @default(7)
  minCookUnits        Float       @default(0)
  maxCookUnits        Float       @default(999)
  reusableLeftover    Boolean     @default(true)
  maxReuseHours       Int         @default(24)
  active              Boolean     @default(true)
  updatedBy           String      @default("System")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt
  cookPlanItems       CookPlanItem[]
  logs                EndOfDayProteinLog[]
  menuItemMappings    MenuItemMapping[]
  posImportRows       PosImportRow[]
  @@unique([restaurantId, name])
  @@index([restaurantId, active])
}

model SavedReport {
  id          String   @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  name        String
  description String?
  source      String
  metric      String
  groupBy     String
  protein     String   @default("all")
  range       String   @default("last30")
  start       String
  end         String
  createdBy   String   @default("Archer")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  @@index([restaurantId, createdAt])
}

model ReportRun {
  id          String   @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  source      String
  metric      String
  groupBy     String
  protein     String   @default("all")
  start       String
  end         String
  dataset     String   @default("aggregate")
  rowCount    Int      @default(0)
  totalValue  Float    @default(0)
  createdBy   String   @default("Archer")
  createdAt   DateTime @default(now())
  @@index([restaurantId, createdAt])
}

model ForecastScenario {
  id               String       @id @default(cuid())
  restaurantId     String?
  restaurant       Restaurant? @relation(fields: [restaurantId], references: [id])
  name             String
  type             ScenarioType
  annualSales      Float
  bbqSalesPercent  Float        @default(40)
  safetyFactorPct  Float        @default(8)
  brisketMixPct    Float        @default(30)
  porkMixPct       Float        @default(40)
  ribsMixPct       Float        @default(15)
  chickenMixPct    Float        @default(15)
  averagePricePerLbCooked Float @default(31)
  updatedBy        String       @default("System")
  createdAt        DateTime     @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt
  cookPlans        CookPlan[]
  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model DayMultiplier {
  id          String   @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  dayOfWeek   Int
  label       String
  multiplier  Float    @default(1)
  updatedBy   String   @default("System")
  updatedAt           DateTime    @default(now()) @updatedAt
  @@unique([restaurantId, dayOfWeek])
}

model MonthMultiplier {
  id          String   @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  month       Int
  label       String
  multiplier  Float    @default(1)
  updatedBy   String   @default("System")
  updatedAt           DateTime    @default(now()) @updatedAt
  @@unique([restaurantId, month])
}

model EventModifier {
  id          String   @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  name        String
  startsOn    DateTime
  endsOn      DateTime
  multiplier  Float    @default(1.25)
  notes       String?
  createdAt   DateTime @default(now())
  @@index([restaurantId, startsOn, endsOn])
}

model CookPlan {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  serviceDate     DateTime
  scenarioId      String
  scenario        ForecastScenario @relation(fields: [scenarioId], references: [id])
  forecastSales   Float
  forecastBbqSales Float
  confidence      String   @default("LOW")
  status          String   @default("DRAFT")
  notes           String?
  createdBy       String   @default("Archer")
  createdAt       DateTime @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt
  items           CookPlanItem[]
  @@unique([restaurantId, serviceDate, scenarioId])
  @@index([restaurantId, serviceDate])
  @@index([scenarioId])
}

model CookPlanItem {
  id                    String   @id @default(cuid())
  restaurantId          String
  restaurant            Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  cookPlanId            String
  cookPlan              CookPlan @relation(fields: [cookPlanId], references: [id], onDelete: Cascade)
  proteinId             String
  protein               Protein @relation(fields: [proteinId], references: [id])
  cookedLbNeeded        Float
  usableLeftoverLb      Float    @default(0)
  usableLeftoverUnits   Float    @default(0)
  forecastCookUnits     Float    @default(0)
  safetyFactorPct       Float
  rawLbNeeded           Float
  recommendedCookUnits  Float
  approvedCookUnits     Float?
  overrideReason        String?
  notes                 String?
  @@index([restaurantId, cookPlanId])
  @@index([restaurantId, proteinId])
}

model EndOfDayLog {
  id             String   @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  serviceDate    DateTime
  enteredBy       String   @default("KM")
  totalSales      Float    @default(0)
  bbqSales        Float    @default(0)
  status          String   @default("DRAFT")
  notes           String?
  reviewedAt      DateTime?
  lockedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt
  proteinLogs     EndOfDayProteinLog[]
  @@unique([restaurantId, serviceDate])
  @@index([restaurantId, serviceDate])
}

model EndOfDayProteinLog {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  endOfDayLogId   String
  endOfDayLog     EndOfDayLog @relation(fields: [endOfDayLogId], references: [id], onDelete: Cascade)
  proteinId       String
  protein         Protein @relation(fields: [proteinId], references: [id])
  cookedUnits     Float    @default(0)
  soldCookedLb    Float    @default(0)
  usableLeftoverLb Float   @default(0)
  usableLeftoverUnits Float @default(0)
  sealedUnopenedUnits Float @default(0)
  openedMeatLb     Float    @default(0)
  wasteLb         Float    @default(0)
  eightySixed     Boolean  @default(false)
  wasteReason     String?
  @@index([restaurantId, endOfDayLogId])
  @@index([restaurantId, proteinId])
  @@unique([endOfDayLogId, proteinId])
  @@unique([restaurantId, endOfDayLogId, proteinId])
}

model SecurityEvent {
  id         String   @id @default(cuid())
  userId     String?
  identifier String?
  action     String
  reason     String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Smoker {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  catalogId    String?
  catalog      SmokerCatalog? @relation(fields: [catalogId], references: [id])
  name         String
  brand        String?
  model        String?
  location     String?
  rackCount    Int      @default(0)
  brisketCapacity Float @default(0)
  porkCapacity Float    @default(0)
  ribCapacity Float     @default(0)
  chickenCapacity Float @default(0)
  cookWindow   String?
  configurationReviewedAt DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  @@unique([restaurantId, name])
  @@index([restaurantId, active])
  @@index([catalogId])
}

model SmokerCatalog {
  id              String   @id @default(cuid())
  brand           String
  model           String
  series          String?
  smokerType      String
  fuelType        String
  rackCount       Int?
  rackWidthIn     Float?
  rackDepthIn     Float?
  cookingAreaSqIn Float?
  brisketCapacity Float?
  porkCapacity    Float?
  ribCapacity     Float?
  chickenCapacity Float?
  cookWindow      String?
  notes           String?
  sourceUrl       String?
  sourceLabel     String?
  officialCapacityText String?
  brisketCapacityUnit String?
  porkCapacityUnit String?
  ribCapacityUnit String?
  chickenCapacityUnit String?
  sourceConfidence String  @default("RESEARCHED")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  smokers         Smoker[]

  @@unique([brand, model])
  @@index([brand, active])
  @@index([sourceConfidence])
}

model LearningRecommendation {
  id           String   @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  type         String
  title        String
  recommendation String
  targetEntity String?
  targetId     String?
  settingKey   String?
  beforeJson   String?
  afterJson    String?
  confidence   String   @default("LOW")
  sampleCount  Int      @default(0)
  minimumSampleCount Int @default(0)
  status       String   @default("PENDING")
  createdBy    String   @default("System")
  decidedBy    String?
  decidedAt    DateTime?
  appliedAt    DateTime?
  rolledBackAt DateTime?
  rollbackBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  @@index([restaurantId, status, createdAt])
}


model SystemCheck {
  id           String   @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  type         String
  status       String   @default("PENDING")
  notes        String?
  verifiedBy   String   @default("System")
  createdAt    DateTime @default(now())
  @@index([restaurantId, type, createdAt])
}
model RateLimitBucket {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @default(now()) @updatedAt
}



model Subscription {
  id                   String   @id @default(cuid())
  restaurantId         String
  restaurant           Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  plan                 String   @default("PILOT")
  status               String   @default("TRIALING")
  trialEndsAt          DateTime?
  currentPeriodEndsAt  DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripeCheckoutUrl    String?
  stripePortalUrl      String?
  cancellationReason   String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt
  @@index([restaurantId, status])
  @@index([stripeCustomerId])
}

model SupportTicket {
  id           String   @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  name         String
  email        String
  subject      String
  message      String
  priority     String   @default("NORMAL")
  status       String   @default("OPEN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  @@index([restaurantId, status, createdAt])
  @@index([email])
}

model CustomerDataRequest {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type         String
  status       String   @default("PENDING")
  requestedBy  String   @default("System")
  notes        String?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  @@index([restaurantId, type, status, createdAt])
}

model MenuItemMapping {
  id             String   @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  posItemName    String
  normalizedName String
  proteinId      String?
  protein        Protein? @relation(fields: [proteinId], references: [id], onDelete: SetNull)
  portionSizeLb  Float    @default(0)
  yieldFactor    Float    @default(1)
  active         Boolean  @default(true)
  source         String   @default("CSV")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  @@unique([restaurantId, normalizedName])
  @@index([restaurantId, active])
  @@index([restaurantId, proteinId])
}


model PosConnection {
  id                    String              @id @default(cuid())
  restaurantId          String
  restaurant            Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  provider              PosProvider
  status                PosConnectionStatus @default(NOT_CONNECTED)
  externalMerchantId    String?
  externalLocationId    String?
  externalLocationName  String?
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  automaticSyncEnabled  Boolean             @default(false)
  dailySyncTime         String              @default("03:00")
  syncTimezone          String              @default("America/New_York")
  syncCursor             String?
  lastSuccessfulSyncAt  DateTime?
  lastAttemptedSyncAt   DateTime?
  lastError              String?
  lastErrorAt            DateTime?
  createdBy              String              @default("System")
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @default(now()) @updatedAt
  syncRuns               PosSyncRun[]
  rawRecords             PosRawRecord[]
  menuItems              PosMenuItem[]
  orders                 PosOrder[]
  webhookEvents          PosWebhookEvent[]
  @@unique([restaurantId, provider, externalLocationId])
  @@index([restaurantId, status])
  @@index([automaticSyncEnabled, status, lastSuccessfulSyncAt])
}

model PosSyncRun {
  id              String        @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  connectionId    String
  connection      PosConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  status          PosSyncStatus @default(QUEUED)
  trigger         String        @default("MANUAL")
  startedAt       DateTime?
  completedAt     DateTime?
  rangeStart      DateTime?
  rangeEnd        DateTime?
  cursorBefore    String?
  cursorAfter     String?
  ordersRead      Int           @default(0)
  lineItemsRead   Int           @default(0)
  rawRecordsSaved Int           @default(0)
  unmappedItems   Int           @default(0)
  errorMessage    String?
  createdAt       DateTime      @default(now())
  @@index([restaurantId, createdAt])
  @@index([connectionId, status, createdAt])
}

model PosRawRecord {
  id               String        @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  connectionId     String
  connection       PosConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  provider         PosProvider
  externalRecordId String
  recordType       String
  businessDate     DateTime?
  payload          Json
  payloadHash      String
  receivedAt       DateTime      @default(now())
  processedAt      DateTime?
  processingError  String?
  @@unique([connectionId, recordType, externalRecordId])
  @@index([restaurantId, businessDate])
  @@index([connectionId, processedAt])
}

model PosMenuItem {
  id               String        @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  connectionId     String
  connection       PosConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  provider         PosProvider
  externalItemId   String
  externalName     String
  normalizedName   String
  categoryName     String?
  active           Boolean       @default(true)
  lastSeenAt       DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  @@unique([connectionId, externalItemId])
  @@index([restaurantId, active])
  @@index([restaurantId, normalizedName])
}

model PosOrder {
  id               String        @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  connectionId     String
  connection       PosConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  provider         PosProvider
  externalOrderId  String
  externalCheckId  String?
  businessDate     DateTime
  openedAt         DateTime?
  closedAt         DateTime?
  grossSalesCents  Int           @default(0)
  discountCents    Int           @default(0)
  netSalesCents    Int           @default(0)
  taxCents         Int           @default(0)
  tipCents         Int           @default(0)
  refundCents      Int           @default(0)
  serviceChargeCents Int         @default(0)
  voided           Boolean       @default(false)
  diningOption     String?
  revenueCenter    String?
  rawUpdatedAt     DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  lineItems        PosLineItem[]
  @@unique([connectionId, externalOrderId])
  @@index([restaurantId, businessDate])
  @@index([connectionId, rawUpdatedAt])
}

model PosLineItem {
  id                 String     @id @default(cuid())
  restaurantId       String
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderId            String
  order              PosOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  externalLineItemId String
  externalItemId     String?
  itemName           String
  categoryName       String?
  quantity           Float      @default(0)
  grossSalesCents    Int        @default(0)
  discountCents      Int        @default(0)
  netSalesCents      Int        @default(0)
  taxCents           Int        @default(0)
  refundCents        Int        @default(0)
  voided             Boolean    @default(false)
  modifierNames      Json?
  mappedProteinId    String?
  estimatedCookedLb  Float      @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @default(now()) @updatedAt
  @@unique([orderId, externalLineItemId])
  @@index([restaurantId, createdAt])
  @@index([restaurantId, externalItemId])
}

model PosWebhookEvent {
  id               String        @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  connectionId     String
  connection       PosConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  provider         PosProvider
  externalEventId  String
  eventType        String
  payload          Json
  signatureValid   Boolean       @default(false)
  receivedAt       DateTime      @default(now())
  processedAt      DateTime?
  processingError  String?
  @@unique([connectionId, externalEventId])
  @@index([restaurantId, receivedAt])
  @@index([connectionId, processedAt])
}

model PosImportBatch {
  id             String   @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  source         String   @default("CSV")
  status         String   @default("PREVIEWED")
  rowCount       Int      @default(0)
  validRowCount  Int      @default(0)
  invalidRowCount Int     @default(0)
  unmappedCount  Int      @default(0)
  totalSales     Float    @default(0)
  bbqSales       Float    @default(0)
  importedBy     String   @default("System")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  rows           PosImportRow[]
  @@index([restaurantId, createdAt])
  @@index([restaurantId, status])
}

model PosImportRow {
  id             String   @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  batchId        String
  batch          PosImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  serviceDate    DateTime
  itemName       String
  quantity       Float    @default(0)
  grossSales     Float    @default(0)
  mappedProteinId String?
  mappedProtein  Protein? @relation(fields: [mappedProteinId], references: [id], onDelete: SetNull)
  portionSizeLb  Float    @default(0)
  estimatedCookedLb Float @default(0)
  valid          Boolean  @default(true)
  reason         String?
  createdAt      DateTime @default(now())
  @@index([restaurantId, serviceDate])
  @@index([restaurantId, batchId])
  @@index([restaurantId, mappedProteinId])
}

