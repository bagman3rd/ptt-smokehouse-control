{
  "name": "ptt-smokehouse-control",
  "version": "1.4.6",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "echo \"migrations disabled for MVP; use prisma db push\"",
    "prisma:seed": "tsx prisma/seed.ts",
    "render-build": "prisma generate && prisma db push --accept-data-loss && tsx prisma/seed.ts && next build",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=10"
  },
  "packageManager": "pnpm@9.15.0"
}
