{
  "name": "ptt-smokehouse-control",
  "version": "5.6.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "render-build": "prisma generate && (prisma migrate resolve --rolled-back 20260712000300_build_470_tenant_constraints || true) && prisma migrate deploy && tsx prisma/seed.ts && next build",
    "db:seed": "tsx prisma/seed.ts",
    "migration:status": "prisma migrate status",
    "test:tenant": "tsx scripts/tenant-integration-test.mjs",
    "test:forecast": "tsx scripts/forecast-engine-test.ts",
    "test:backup": "node scripts/backup-restore-drill-check.mjs",
    "build:eval": "node scripts/build-5-6-0-evaluation.mjs",
    "migration:baseline:check": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "render-build:migrate-ready": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts && next build",
    "backup:weekly": "node scripts/run-weekly-backup-cron.mjs",
    "typecheck": "tsc --noEmit",
    "test:permissions": "node scripts/permission-boundary-test.mjs",
    "ci:schema-drift": "prisma migrate diff --from-url \"$DATABASE_URL\" --to-schema-datamodel prisma/schema.prisma --exit-code",
    "ci:migration-status": "prisma migrate status",
    "ci:test": "pnpm run preflight && pnpm run typecheck && pnpm run lint && pnpm run test:forecast && pnpm run test:permissions && pnpm run test:account-security && pnpm run test:dead-code && pnpm run test:tenant && pnpm run test:cross-tenant && pnpm run test:tenant-guard && pnpm run test:orphan-records && pnpm run staging:verify && pnpm run test:pos-import && pnpm run test:demo-docs && pnpm run test:smoker-catalog && pnpm run ci:schema-drift",
    "test:dead-code": "node scripts/dead-code-check.mjs",
    "test:cross-tenant": "tsx scripts/cross-tenant-regression-test.mjs",
    "test:account-security": "node scripts/account-security-test.mjs",
    "billing:check": "node scripts/billing-config-check.mjs",
    "preflight": "node scripts/preflight-build-check.mjs",
    "staging:verify": "node scripts/staging-verification-check.mjs",
    "test:tenant-guard": "node scripts/tenant-guard-coverage-test.mjs",
    "test:orphan-records": "node scripts/orphan-record-check.mjs",
    "test:pos-import": "node scripts/pos-import-mapping-test.mjs",
    "test:demo-docs": "node scripts/demo-docs-test.mjs",
    "test:smoker-catalog": "node scripts/smoker-catalog-test.mjs"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=10"
  },
  "packageManager": "pnpm@9.15.0"
}
